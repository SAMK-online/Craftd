# Anthropic (required) — OCR + brief/outreach generation
ANTHROPIC_API_KEY=sk-ant-...

# Tavily (enrichment via live web research) — get a free key at tavily.com
# Works from just a name + company. Without it, briefs still generate from
# public data + job boards, just without deep person/company research.
TAVILY_API_KEY=tvly-...
# Results per Tavily query (1-10)
TAVILY_MAX_RESULTS=5

# Prospeo (verified email finder) — free tier ~75/mo at prospeo.io
# Finds a work email from name + company domain. Optional; brief still works without it.
PROSPEO_API_KEY=

# Exa (powers "Find people") — pay-as-you-go key at exa.ai
# Discovers contacts from a search ("Solutions Engineers at Anthropic") or an
# event link. Without it, "Find people" is unavailable; the rest still works.
EXA_API_KEY=

# Job board scraping (optional fallback for companies not on Greenhouse/Lever/Ashby)
# Apify (managed scraping)
APIFY_API_TOKEN=apify_api_...
# Direct LinkedIn (requires cookies/session - see README)
LINKEDIN_SCRAPE_ENABLED=false

# App config
APP_ENV=development
LOG_LEVEL=INFO

# Supabase (persona + contact history DB)
# Project Settings -> API: URL + service_role key (backend only)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-key
