# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Clay
# Get from: app.clay.com → Settings → API Keys
CLAY_API_KEY=clay_...
# Your Clay table webhook URL for enrichment triggers
CLAY_TABLE_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/...
# Clay table ID (from the table URL: app.clay.com/.../tables/TABLE_ID).
# Without it, Clay runs in webhook-only mode (no row polling / enrichment readback).
CLAY_TABLE_ID=

# Job board scraping (pick one approach)
# Option A: Apify (managed scraping, easiest to start)
APIFY_API_TOKEN=apify_api_...
# Option B: Direct LinkedIn (requires cookies/session - see README)
LINKEDIN_SCRAPE_ENABLED=false

# App config
APP_ENV=development
LOG_LEVEL=INFO
# How long to wait for Clay enrichment before falling back (seconds)
CLAY_TIMEOUT_SECONDS=12
